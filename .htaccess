Options -Indexes

# PHP upload limits (mod_php)
<IfModule mod_php.c>
    php_value upload_max_filesize 50M
    php_value post_max_size 60M
    php_value max_file_uploads 25
    php_value memory_limit 256M
    php_value max_execution_time 120
</IfModule>

# Prevent access to sensitive files
<FilesMatch "\.(env|log|lock|json|md|gitignore|editorconfig|ini|sh|bat)$">
    Require all denied
</FilesMatch>

# Block direct access to artisan / composer
<FilesMatch "^(artisan|composer\.phar)$">
    Require all denied
</FilesMatch>

# Route all requests through public/ so /public never appears in the URL
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Pass Authorization header through
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Block direct access to private storage areas
    RewriteRule ^storage/app/private - [F,L]
    RewriteRule ^storage/framework - [F,L]
    RewriteRule ^storage/logs - [F,L]

    # Serve real files and directories directly (css, js, images inside public/)
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Serve uploaded files directly from storage (no symlink needed)
    RewriteRule ^storage/(.+)$ storage/app/public/$1 [L]

    # Everything else goes to public/index.php (Laravel front controller)
    RewriteRule ^ public/index.php [L]
</IfModule>

DirectoryIndex index.php
